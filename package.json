{
  "name": "newton-future-portfolio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "build:frontend": "npm --prefix apps/frontend run build",
    "start:frontend": "npm --prefix apps/frontend run start",
    "dev:backend": "uvicorn apps.backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "start:backend": "uvicorn apps.backend.app.main:app --host 0.0.0.0 --port 8000",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:dev": "node --watch server.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  }
}
